# =============================================================================
# PRODUCTION ENVIRONMENT — Set these in your hosting provider (e.g., Vercel)
# Do NOT commit this file with real values. This is a template.
# =============================================================================

NODE_ENV="production"

# App URL — your production domain
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXTAUTH_URL="https://your-domain.com"

# Auth secret — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=""

# Database — use pooled connection (port 6543) for production
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# OAuth encryption
OAUTH_ENCRYPTION_KEY=""

# Google / YouTube OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Instagram OAuth
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# Pusher
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Supabase
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_STORAGE_BUCKET="deliverables"

# Inngest
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
ESCROW_RELEASE_DELAY="7d"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Gridlines (KYC/KYB)
GSTIN_API_URL="https://api.gridlines.io/gstin-api/gst"
GSTIN_API_KEY=""

# Redis (Upstash)
REDIS_URL=""

# Apify
APIFY_API_TOKEN=""

# Timezone
TZ=Asia/Kolkata
