# Database
DATABASE_URL="postgresql://user:password@localhost:5432/quickcollab?schema=public"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# KYC Provider (Digio)
DIGIO_API_KEY="your-digio-api-key"
DIGIO_API_SECRET="your-digio-api-secret"
DIGIO_WEBHOOK_SECRET="your-digio-webhook-secret"

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="quickcollab-files"

# Redis (Caching & Sessions)
REDIS_URL="redis://localhost:6379"

# Email (Resend)
RESEND_API_KEY="your-resend-api-key"

# SMS (MSG91 for India)
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_SENDER_ID="QCKCLB"

# Monitoring
SENTRY_DSN="your-sentry-dsn"

# Application
NODE_ENV="development"
PORT=3000
