# =============================================================================
# SUPABASE (Database)
# =============================================================================
# Go to https://supabase.com → Create Project → Settings → Database
# Use the "Connection string" (URI) from the database settings page.
# For connection pooling (recommended), use the "Transaction" pooler URL on port 6543.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for migrations only — NOT for the app)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# =============================================================================
# Authentication
# =============================================================================
NEXTAUTH_SECRET="generate-a-strong-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# Gridlines (KYC + KYB — PAN, Aadhaar, GSTIN verification)
# Sign up at https://app.gridlines.io for API access.
# One API key covers both KYC (PAN/Aadhaar) and KYB (GSTIN).
# In dev without an API key, KYC verification auto-passes (mock mode).
# =============================================================================
GSTIN_API_URL="https://api.gridlines.io/gstin-api/gst"
GSTIN_API_KEY="your-gridlines-api-key"

# =============================================================================
# Payment Gateway (Razorpay)
# =============================================================================
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# =============================================================================
# Supabase Storage (File Storage)
# =============================================================================
# Go to Supabase dashboard → Settings → API for URL and service role key.
# Create a private bucket named "deliverables" in Storage dashboard.
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="deliverables"

# =============================================================================
# AWS Lambda (Video Processing — separate from storage)
# =============================================================================
AWS_REGION="ap-south-1"
VIDEO_LAMBDA_FUNCTION_NAME="influencer-connect-video-processor"
VIDEO_LAMBDA_REGION="ap-south-1"
S3_RAW_PREFIX="raw/"
S3_PROCESSED_PREFIX="processed/"
HLS_PRESIGNED_URL_EXPIRY=900

# =============================================================================
# Redis (Rate Limiting — optional for dev, uses in-memory fallback)
# =============================================================================
# Get a free Redis instance at https://upstash.com
REDIS_URL=""

# =============================================================================
# OAuth (Social Media Login)
# =============================================================================
# Instagram (Meta for Developers — https://developers.facebook.com)
# Create App → "Business" type → Add "Instagram Graph API" product
# Add redirect URI: http://localhost:3000/api/oauth/instagram/callback
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# YouTube (Google Cloud Console — https://console.cloud.google.com)
# Enable "YouTube Data API v3" → Create OAuth 2.0 Client ID (Web)
# Add redirect URI: http://localhost:3000/api/oauth/youtube/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Used for OAuth token encryption (AES-256-GCM). Falls back to NEXTAUTH_SECRET if not set.
OAUTH_ENCRYPTION_KEY=""

# Base URL for OAuth callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# Application
# =============================================================================
NODE_ENV="development"
PORT=3000
