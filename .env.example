# =============================================================================
# SUPABASE (Database)
# =============================================================================
# Go to https://supabase.com → Create Project → Settings → Database
# Use the "Connection string" (URI) from the database settings page.
# For connection pooling (recommended), use the "Transaction" pooler URL on port 6543.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for migrations only — NOT for the app)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# =============================================================================
# Authentication
# =============================================================================
NEXTAUTH_SECRET="generate-a-strong-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# KYC Provider (Digio)
# =============================================================================
DIGIO_API_KEY="your-digio-api-key"
DIGIO_API_SECRET="your-digio-api-secret"
DIGIO_WEBHOOK_SECRET="your-digio-webhook-secret"

# =============================================================================
# Payment Gateway (Razorpay)
# =============================================================================
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# =============================================================================
# AWS S3 (File Storage)
# =============================================================================
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="quickcollab-files"

# =============================================================================
# Redis (Rate Limiting — optional for dev, uses in-memory fallback)
# =============================================================================
# Get a free Redis instance at https://upstash.com
REDIS_URL=""

# =============================================================================
# Application
# =============================================================================
NODE_ENV="development"
PORT=3000
